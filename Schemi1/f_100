            displayResults(results);
            
            // Show results section
            document.getElementById('resultsSection').classList.add('visible');
            document.getElementById('resultsSection').scrollIntoView({ behavior: 'smooth' });
        }

        function calculateErrorScores() {
            const allScores = [];
            let totalError = 0;
            const trayTotals = { 1: 0, 2: 0, 3: 0, 4: 0 };
            
            for (let t = 1; t <= 4; t++) {
                const trayData = FM100_COLORS[`tray${t}`];
                const arrangement = trayStates[t];
                const trayScores = [];
                
                for (let i = 0; i < arrangement.length; i++) {
                    const cap = arrangement[i];
                    let error = 0;
                    
                    // Get neighbors (considering reference caps at ends)
                    const prevId = i === 0 ? trayData.reference.start : arrangement[i - 1].id;
                    const nextId = i === arrangement.length - 1 ? trayData.reference.end : arrangement[i + 1].id;
                    
                    // Error = |difference from previous| + |difference from next| - 2
                    // (Perfect placement would give 2, so we subtract 2 to get 0 error)
                    error = Math.abs(cap.id - prevId) + Math.abs(cap.id - nextId) - 2;
                    error = Math.max(0, error); // No negative errors
                    
                    trayScores.push({
                        capId: cap.id,
                        error: error,
                        position: i,
                        tray: t,
                        hue: cap.hue
                    });
                    
                    totalError += error;
                    trayTotals[t] += error;
                }
                
                allScores.push(...trayScores);
            }
            
            // Calculate axis involvement
            const axisAnalysis = analyzeConfusionAxes(allScores);
            
            return {
                totalError: totalError,
                trayTotals: trayTotals,
                scores: allScores,
                axisAnalysis: axisAnalysis,
                duration: elapsedSeconds
            };
        }

        function analyzeConfusionAxes(scores) {
            // Confusion axes based on Munsell hue positions
            // Protan: errors around 5R-10YR (caps 70-85, 1-10)
            // Deutan: errors around 10GY-5G (caps 25-40)
            // Tritan: errors around 5PB-5P (caps 50-70)
            
            const protan = scores.filter(s => 
                (s.capId >= 70 && s.capId <= 84) || (s.capId >= 1 && s.capId <= 10)
            ).reduce((sum, s) => sum + s.error, 0);
            
            const deutan = scores.filter(s => 
                s.capId >= 25 && s.capId <= 45
            ).reduce((sum, s) => sum + s.error, 0);
            
            const tritan = scores.filter(s => 
                s.capId >= 46 && s.capId <= 70
            ).reduce((sum, s) => sum + s.error, 0);
            
            // Determine primary axis
            const maxError = Math.max(protan, deutan, tritan);
            let primaryAxis = 'Normal';
            
            if (maxError > 20) {
                if (protan === maxError) primaryAxis = 'Protan';
                else if (deutan === maxError) primaryAxis = 'Deutan';
                else primaryAxis = 'Tritan';
            }
            
            return {
                protan: protan,
                deutan: deutan,
                tritan: tritan,
                primaryAxis: primaryAxis
            };
        }

        function displayResults(results) {
            // Total Error Score
            const tesEl = document.getElementById('tesValue');
            tesEl.textContent = results.totalError;
            
            // Classification
            let classification, cssClass;
            if (results.totalError <= 16) {
                classification = 'Eccellente discriminazione cromatica';
                cssClass = 'excellent';
            } else if (results.totalError <= 40) {
                classification = 'Discriminazione cromatica normale';
                cssClass = 'good';
            } else if (results.totalError <= 100) {
                classification = 'Discriminazione cromatica media/sotto la media';
                cssClass = 'average';
            } else {
                classification = 'Discriminazione cromatica ridotta';
                cssClass = 'poor';
            }
            
            tesEl.className = 'tes-value ' + cssClass;
            document.getElementById('tesInterpretation').textContent = classification;
            
            // Draw polar chart
            drawPolarChart(results.scores);
            
            // Diagnosis
            const diagContent = document.getElementById('diagnosisContent');
            diagContent.innerHTML = `
