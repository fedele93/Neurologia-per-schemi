        function initializeTrays() {
            for (let t = 1; t <= 4; t++) {
                const trayData = FM100_COLORS[`tray${t}`];
                trayStates[t] = shuffleArray([...trayData.caps]);
            }
            updateProgress();
        }

        function shuffleArray(array) {
            const shuffled = [...array];
            for (let i = shuffled.length - 1; i > 0; i--) {
                const j = Math.floor(Math.random() * (i + 1));
                [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
            }
            return shuffled;
        }

        function switchTray(trayNum) {
            currentTray = trayNum;
            
            // Update tab states
            document.querySelectorAll('.tab').forEach(tab => {
                tab.classList.toggle('active', parseInt(tab.dataset.tray) === trayNum);
            });
            
            renderTray(trayNum);
        }

        function renderTray(trayNum) {
            const trayData = FM100_COLORS[`tray${trayNum}`];
            const caps = trayStates[trayNum];
            
            const container = document.getElementById('trayContents');
            container.innerHTML = `
                <section class="tray-section">
                    <div class="tray-container">
                        <div class="reference-caps">
                            <div class="reference-cap">
                                <div class="reference-cap-color" style="background: ${trayData.referenceColors.start}"></div>
                                <span>Inizio</span>
                            </div>
                            <div class="reference-cap">
                                <div class="reference-cap-color" style="background: ${trayData.referenceColors.end}"></div>
                                <span>Fine</span>
                            </div>
                        </div>
                        <div class="caps-row ${showNumbers ? 'show-numbers' : ''}" id="capsRow" 
                             ondragover="handleDragOver(event)" 
                             ondrop="handleDrop(event)"
                             ondragleave="handleDragLeave(event)">
                            ${caps.map((cap, index) => `
                                <div class="cap" 
                                     draggable="true"
                                     data-id="${cap.id}"
                                     data-index="${index}"
                                     style="background: ${cap.rgb}"
                                     ondragstart="handleDragStart(event)"
                                     ondragend="handleDragEnd(event)">
