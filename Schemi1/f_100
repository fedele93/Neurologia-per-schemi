<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Farnsworth-Munsell 100 Hue Test</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-primary: #0a0a0f;
            --bg-secondary: #12121a;
            --bg-tertiary: #1a1a26;
            --text-primary: #f0f0f5;
            --text-secondary: #8888a0;
            --text-muted: #555570;
            --accent: #6366f1;
            --accent-light: #818cf8;
            --success: #10b981;
            --warning: #f59e0b;
            --error: #ef4444;
            --border: #2a2a3a;
            --shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            --radius: 12px;
            --radius-lg: 20px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            min-height: 100vh;
            line-height: 1.6;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 2rem;
        }

        header {
            text-align: center;
            padding: 3rem 0;
            border-bottom: 1px solid var(--border);
            margin-bottom: 2rem;
        }

        h1 {
            font-family: 'Instrument Serif', serif;
            font-size: clamp(2rem, 5vw, 3.5rem);
            font-weight: 400;
            margin-bottom: 0.5rem;
            background: linear-gradient(135deg, var(--text-primary), var(--accent-light));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .subtitle {
            color: var(--text-secondary);
            font-size: 1.1rem;
        }

        /* Patient Info Section */
        .patient-section {
            background: var(--bg-secondary);
            border-radius: var(--radius-lg);
            padding: 2rem;
            margin-bottom: 2rem;
            border: 1px solid var(--border);
        }

        .patient-section h2 {
            font-family: 'Instrument Serif', serif;
            font-size: 1.5rem;
            margin-bottom: 1.5rem;
            color: var(--text-primary);
        }

        .patient-form {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .form-group label {
            font-size: 0.85rem;
            color: var(--text-secondary);
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .form-group input, .form-group select {
            background: var(--bg-tertiary);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 0.75rem 1rem;
            color: var(--text-primary);
            font-family: inherit;
            font-size: 1rem;
            transition: border-color 0.2s, box-shadow 0.2s;
        }

        .form-group input:focus, .form-group select:focus {
            outline: none;
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.2);
        }

        /* Instructions */
        .instructions {
            background: linear-gradient(135deg, rgba(99, 102, 241, 0.1), rgba(129, 140, 248, 0.05));
            border: 1px solid rgba(99, 102, 241, 0.3);
            border-radius: var(--radius-lg);
            padding: 1.5rem 2rem;
            margin-bottom: 2rem;
        }

        .instructions h3 {
            color: var(--accent-light);
            margin-bottom: 0.75rem;
            font-size: 1.1rem;
        }

        .instructions p {
            color: var(--text-secondary);
            font-size: 0.95rem;
        }

        .instructions ul {
            margin-top: 0.75rem;
            padding-left: 1.5rem;
            color: var(--text-secondary);
        }

        .instructions li {
            margin-bottom: 0.5rem;
        }

        /* Test Controls */
        .test-controls {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
            justify-content: center;
            margin-bottom: 2rem;
        }

        .btn {
            padding: 0.875rem 2rem;
            border-radius: var(--radius);
            font-family: inherit;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            border: none;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }

        .btn-primary {
            background: var(--accent);
            color: white;
        }

        .btn-primary:hover {
            background: var(--accent-light);
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(99, 102, 241, 0.3);
        }

        .btn-secondary {
            background: var(--bg-tertiary);
            color: var(--text-primary);
            border: 1px solid var(--border);
        }

        .btn-secondary:hover {
            background: var(--border);
        }

        .btn-success {
            background: var(--success);
            color: white;
        }

        .btn-success:hover {
            background: #0ea371;
        }

        .btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }

        /* Tray Section */
        .tray-section {
            margin-bottom: 3rem;
        }

        .tray-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
        }

        .tray-title {
            font-family: 'Instrument Serif', serif;
            font-size: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .tray-badge {
            background: var(--accent);
            color: white;
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            font-family: 'DM Sans', sans-serif;
            font-size: 0.85rem;
            font-weight: 600;
        }

        .tray-container {
            background: var(--bg-secondary);
            border-radius: var(--radius-lg);
            padding: 2rem;
            border: 1px solid var(--border);
        }

        .reference-caps {
            display: flex;
            justify-content: space-between;
            margin-bottom: 1rem;
            padding: 0 0.5rem;
        }

        .reference-cap {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.5rem;
        }

        .reference-cap-color {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            border: 3px solid var(--text-muted);
            box-shadow: inset 0 2px 4px rgba(0,0,0,0.3);
        }

        .reference-cap span {
            font-size: 0.75rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.1em;
        }

        .caps-row {
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
            justify-content: center;
            min-height: 70px;
            padding: 1rem;
            background: var(--bg-tertiary);
            border-radius: var(--radius);
            border: 2px dashed var(--border);
            transition: border-color 0.2s, background 0.2s;
        }

        .caps-row.drag-over {
            border-color: var(--accent);
            background: rgba(99, 102, 241, 0.1);
        }

        .cap {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            cursor: grab;
            transition: transform 0.15s, box-shadow 0.15s;
            border: 2px solid rgba(255,255,255,0.1);
            box-shadow: 0 2px 8px rgba(0,0,0,0.3), inset 0 2px 4px rgba(255,255,255,0.1);
            position: relative;
        }

        .cap:hover {
            transform: scale(1.15);
            box-shadow: 0 8px 20px rgba(0,0,0,0.4);
            z-index: 10;
        }

        .cap.dragging {
            opacity: 0.5;
            cursor: grabbing;
        }

        .cap.error-highlight {
            animation: pulse-error 1s ease-in-out infinite;
        }

        @keyframes pulse-error {
            0%, 100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.5); }
            50% { box-shadow: 0 0 0 8px rgba(239, 68, 68, 0); }
        }

        .cap-number {
            position: absolute;
            bottom: -20px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 0.7rem;
            color: var(--text-muted);
            opacity: 0;
            transition: opacity 0.2s;
        }

        .show-numbers .cap-number {
            opacity: 1;
        }

        /* Tabs */
        .tabs {
            display: flex;
            gap: 0.5rem;
            margin-bottom: 2rem;
            background: var(--bg-secondary);
            padding: 0.5rem;
            border-radius: var(--radius);
            border: 1px solid var(--border);
        }

        .tab {
            flex: 1;
            padding: 1rem;
            background: transparent;
            border: none;
            border-radius: calc(var(--radius) - 4px);
            color: var(--text-secondary);
            font-family: inherit;
            font-size: 1rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
        }

        .tab:hover {
            color: var(--text-primary);
            background: var(--bg-tertiary);
        }

        .tab.active {
            background: var(--accent);
            color: white;
        }

        .tab-content {
            display: none;
        }

        .tab-content.active {
            display: block;
        }

        /* Results Section */
        .results-section {
            background: var(--bg-secondary);
            border-radius: var(--radius-lg);
            padding: 2rem;
            border: 1px solid var(--border);
            margin-top: 2rem;
            display: none;
        }

        .results-section.visible {
            display: block;
            animation: fadeIn 0.5s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .results-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 2rem;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .results-title {
            font-family: 'Instrument Serif', serif;
            font-size: 2rem;
        }

        .total-error-score {
            background: var(--bg-tertiary);
            padding: 1.5rem 2rem;
            border-radius: var(--radius);
            text-align: center;
        }

        .tes-label {
            font-size: 0.85rem;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.1em;
            margin-bottom: 0.25rem;
        }

        .tes-value {
            font-size: 3rem;
            font-weight: 700;
            line-height: 1;
        }

        .tes-value.excellent { color: var(--success); }
        .tes-value.good { color: #22c55e; }
        .tes-value.average { color: var(--warning); }
        .tes-value.poor { color: var(--error); }

        .tes-interpretation {
            font-size: 0.9rem;
            color: var(--text-secondary);
            margin-top: 0.5rem;
        }

        /* Polar Chart */
        .chart-container {
            margin: 2rem 0;
            display: flex;
            justify-content: center;
        }

        #polarChart {
            max-width: 100%;
        }

        /* Error Scores Table */
        .scores-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 1.5rem;
            margin-top: 2rem;
        }

        .tray-scores {
            background: var(--bg-tertiary);
            border-radius: var(--radius);
            padding: 1.5rem;
        }

        .tray-scores h4 {
            font-size: 1.1rem;
            margin-bottom: 1rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .tray-total {
            background: var(--accent);
            color: white;
            padding: 0.25rem 0.75rem;
            border-radius: 20px;
            font-size: 0.85rem;
        }

        .score-row {
            display: flex;
            justify-content: space-between;
            padding: 0.5rem 0;
            border-bottom: 1px solid var(--border);
            font-size: 0.9rem;
        }

        .score-row:last-child {
            border-bottom: none;
        }

        .score-row .cap-id {
            color: var(--text-secondary);
        }

        .score-row .error {
            font-weight: 600;
            min-width: 30px;
            text-align: right;
        }

        .score-row .error.high { color: var(--error); }
        .score-row .error.medium { color: var(--warning); }
        .score-row .error.low { color: var(--success); }

        /* Diagnosis Section */
        .diagnosis-section {
            margin-top: 2rem;
            padding: 1.5rem;
            background: var(--bg-tertiary);
            border-radius: var(--radius);
            border-left: 4px solid var(--accent);
        }

        .diagnosis-section h4 {
            font-size: 1.1rem;
            margin-bottom: 1rem;
            color: var(--accent-light);
        }

        .diagnosis-item {
            display: flex;
            justify-content: space-between;
            padding: 0.75rem 0;
            border-bottom: 1px solid var(--border);
        }

        .diagnosis-item:last-child {
            border-bottom: none;
        }

        .axis-indicator {
            display: inline-block;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            margin-right: 0.5rem;
        }

        .axis-protan { background: #ef4444; }
        .axis-deutan { background: #22c55e; }
        .axis-tritan { background: #3b82f6; }

        /* Clinical Notes */
        .clinical-notes {
            margin-top: 2rem;
        }

        .clinical-notes h4 {
            font-size: 1.1rem;
            margin-bottom: 1rem;
        }

        .clinical-notes textarea {
            width: 100%;
            min-height: 150px;
            background: var(--bg-tertiary);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 1rem;
            color: var(--text-primary);
            font-family: inherit;
            font-size: 0.95rem;
            resize: vertical;
        }

        .clinical-notes textarea:focus {
            outline: none;
            border-color: var(--accent);
        }

        /* Print Styles */
        .print-section {
            margin-top: 2rem;
            display: flex;
            gap: 1rem;
            justify-content: center;
        }

        @media print {
            body {
                background: white;
                color: black;
            }

            .container {
                max-width: 100%;
                padding: 0;
            }

            .test-controls, .tabs, .instructions, .btn, .patient-section input, .patient-section select {
                display: none !important;
            }

            .results-section {
                display: block !important;
                background: white;
                border: 1px solid #ccc;
            }

            .tray-section {
                display: none;
            }

            .patient-section {
                display: block;
                background: white;
                border: 1px solid #ccc;
            }

            .patient-form {
                display: block;
            }

            .form-group {
                display: inline-block;
                margin-right: 2rem;
                margin-bottom: 0.5rem;
            }

            h1, h2, h3, h4 {
                color: black !important;
                -webkit-text-fill-color: black !important;
            }

            .tes-value {
                color: black !important;
            }

            .print-date {
                display: block !important;
            }
        }

        .print-date {
            display: none;
            text-align: right;
            font-size: 0.9rem;
            color: var(--text-muted);
            margin-top: 1rem;
        }

        /* Mobile Responsive */
        @media (max-width: 768px) {
            .container {
                padding: 1rem;
            }

            header {
                padding: 2rem 0;
            }

            .cap {
                width: 36px;
                height: 36px;
            }

            .reference-cap-color {
                width: 40px;
                height: 40px;
            }

            .tray-container {
                padding: 1rem;
            }

            .results-header {
                flex-direction: column;
            }

            .total-error-score {
                width: 100%;
            }
        }

        /* Loading State */
        .loading {
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 3rem;
        }

        .spinner {
            width: 40px;
            height: 40px;
            border: 3px solid var(--border);
            border-top-color: var(--accent);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        /* Timer */
        .timer {
            font-size: 1.25rem;
            font-weight: 600;
            color: var(--text-secondary);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .timer-icon {
            width: 20px;
            height: 20px;
        }

        /* Progress */
        .progress-bar {
            height: 4px;
            background: var(--border);
            border-radius: 2px;
            margin-bottom: 2rem;
            overflow: hidden;
        }

        .progress-fill {
            height: 100%;
            background: var(--accent);
            transition: width 0.3s ease;
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>Farnsworth-Munsell 100 Hue Test</h1>
            <p class="subtitle">Test di discriminazione cromatica per la valutazione clinica</p>
        </header>

        <!-- Patient Information -->
        <section class="patient-section">
            <h2>Dati del Paziente</h2>
            <div class="patient-form">
                <div class="form-group">
                    <label for="patientName">Nome e Cognome</label>
                    <input type="text" id="patientName" placeholder="Es. Mario Rossi">
                </div>
                <div class="form-group">
                    <label for="patientDob">Data di Nascita</label>
                    <input type="date" id="patientDob">
                </div>
                <div class="form-group">
                    <label for="patientEye">Occhio Testato</label>
                    <select id="patientEye">
                        <option value="OD">Occhio Destro (OD)</option>
                        <option value="OS">Occhio Sinistro (OS)</option>
                        <option value="OU">Entrambi (OU)</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="illuminant">Illuminante</label>
                    <select id="illuminant">
                        <option value="D65">D65 (Daylight)</option>
                        <option value="D50">D50</option>
                        <option value="A">Illuminante A</option>
                        <option value="F2">F2 (Fluorescente)</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="examiner">Esaminatore</label>
                    <input type="text" id="examiner" placeholder="Dr. ...">
                </div>
                <div class="form-group">
                    <label for="examDate">Data Esame</label>
                    <input type="date" id="examDate">
                </div>
            </div>
        </section>

        <!-- Instructions -->
        <section class="instructions">
            <h3>📋 Istruzioni per il Test</h3>
            <p>Il test consiste nel riordinare i dischetti colorati in ordine di gradazione cromatica.</p>
            <ul>
                <li>Ogni vassoio ha due <strong>dischetti di riferimento fissi</strong> alle estremità</li>
                <li><strong>Trascina</strong> i dischetti per riordinarli dal colore iniziale a quello finale</li>
                <li>Completa tutti e 4 i vassoi prima di calcolare i risultati</li>
                <li>Il tempo medio per completare il test è di 10-15 minuti</li>
            </ul>
        </section>

        <!-- Test Controls -->
        <div class="test-controls">
            <button class="btn btn-primary" id="startBtn" onclick="startTest()">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polygon points="5 3 19 12 5 21 5 3"></polygon>
                </svg>
                Inizia Test
            </button>
            <button class="btn btn-secondary" id="resetBtn" onclick="resetTest()" disabled>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
                    <path d="M3 3v5h5"></path>
                </svg>
                Reset
            </button>
            <button class="btn btn-secondary" id="showNumbersBtn" onclick="toggleNumbers()">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <line x1="12" y1="16" x2="12" y2="12"></line>
                    <line x1="12" y1="8" x2="12.01" y2="8"></line>
                </svg>
                Mostra Numeri
            </button>
            <div class="timer" id="timer" style="display: none;">
                <svg class="timer-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
                <span id="timerDisplay">00:00</span>
            </div>
        </div>

        <!-- Progress Bar -->
        <div class="progress-bar" id="progressBar" style="display: none;">
            <div class="progress-fill" id="progressFill" style="width: 0%"></div>
        </div>

        <!-- Tray Tabs -->
        <div class="tabs" id="trayTabs" style="display: none;">
            <button class="tab active" data-tray="1">Vassoio 1</button>
            <button class="tab" data-tray="2">Vassoio 2</button>
            <button class="tab" data-tray="3">Vassoio 3</button>
            <button class="tab" data-tray="4">Vassoio 4</button>
        </div>

        <!-- Tray Contents -->
        <div id="trayContents"></div>

        <!-- Calculate Button -->
        <div class="test-controls" id="calcControls" style="display: none;">
            <button class="btn btn-success" id="calculateBtn" onclick="calculateResults()">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                    <polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
                Calcola Risultati
            </button>
        </div>

        <!-- Results Section -->
        <section class="results-section" id="resultsSection">
            <div class="results-header">
                <h2 class="results-title">Risultati del Test</h2>
                <div class="total-error-score">
                    <div class="tes-label">Total Error Score (TES)</div>
                    <div class="tes-value" id="tesValue">--</div>
                    <div class="tes-interpretation" id="tesInterpretation"></div>
                </div>
            </div>

            <div class="print-date" id="printDate"></div>

            <!-- Polar Chart -->
            <div class="chart-container">
                <canvas id="polarChart" width="500" height="500"></canvas>
            </div>

            <!-- Diagnosis -->
            <div class="diagnosis-section">
                <h4>🔬 Analisi degli Assi di Confusione</h4>
                <div id="diagnosisContent"></div>
            </div>

            <!-- Score Details -->
            <div class="scores-grid" id="scoresGrid"></div>

            <!-- Clinical Notes -->
            <div class="clinical-notes">
                <h4>📝 Note Cliniche</h4>
                <textarea id="clinicalNotes" placeholder="Inserire osservazioni cliniche, anamnesi rilevante, condizioni del test..."></textarea>
            </div>

            <!-- Print/Export -->
            <div class="print-section">
                <button class="btn btn-primary" onclick="printResults()">
