        function addTouchSupport() {
            const caps = document.querySelectorAll('.cap');
            let draggedEl = null;
            let initialX, initialY;
            
            caps.forEach(cap => {
                cap.addEventListener('touchstart', (e) => {
                    draggedEl = cap;
                    const touch = e.touches[0];
                    initialX = touch.clientX;
                    initialY = touch.clientY;
                    cap.classList.add('dragging');
                }, { passive: true });
                
                cap.addEventListener('touchmove', (e) => {
                    if (!draggedEl) return;
                    e.preventDefault();
                    
                    const touch = e.touches[0];
                    const row = document.getElementById('capsRow');
                    const caps = Array.from(row.querySelectorAll('.cap:not(.dragging)'));
                    
                    // Find insertion point
                    let insertBefore = null;
                    for (const cap of caps) {
                        const rect = cap.getBoundingClientRect();
                        if (touch.clientX < rect.left + rect.width / 2) {
                            insertBefore = cap;
                            break;
                        }
                    }
                    
                    if (insertBefore) {
                        row.insertBefore(draggedEl, insertBefore);
                    } else {
                        row.appendChild(draggedEl);
                    }
                }, { passive: false });
                
                cap.addEventListener('touchend', () => {
                    if (draggedEl) {
                        draggedEl.classList.remove('dragging');
                        updateTrayState();
                        draggedEl = null;
                    }
                });
            });
        }

        // Drag and Drop
        let draggedElement = null;

        function handleDragStart(e) {
            draggedElement = e.target;
            e.target.classList.add('dragging');
            e.dataTransfer.effectAllowed = 'move';
            e.dataTransfer.setData('text/plain', e.target.dataset.index);
        }

        function handleDragEnd(e) {
            e.target.classList.remove('dragging');
            document.getElementById('capsRow').classList.remove('drag-over');
        }

        function handleDragOver(e) {
            e.preventDefault();
            e.dataTransfer.dropEffect = 'move';
            e.currentTarget.classList.add('drag-over');
            
            // Reorder visual
            const row = e.currentTarget;
            const afterElement = getDragAfterElement(row, e.clientX);
            
            if (afterElement == null) {
                row.appendChild(draggedElement);
            } else {
                row.insertBefore(draggedElement, afterElement);
            }
        }

        function handleDragLeave(e) {
            e.currentTarget.classList.remove('drag-over');
        }

        function handleDrop(e) {
            e.preventDefault();
            e.currentTarget.classList.remove('drag-over');
            updateTrayState();
        }

        function getDragAfterElement(container, x) {
            const draggableElements = [...container.querySelectorAll('.cap:not(.dragging)')];
            
            return draggableElements.reduce((closest, child) => {
                const box = child.getBoundingClientRect();
                const offset = x - box.left - box.width / 2;
                
                if (offset < 0 && offset > closest.offset) {
                    return { offset: offset, element: child };
                } else {
                    return closest;
                }
            }, { offset: Number.NEGATIVE_INFINITY }).element;
        }

        function updateTrayState() {
            const row = document.getElementById('capsRow');
            const caps = Array.from(row.querySelectorAll('.cap'));
            const trayData = FM100_COLORS[`tray${currentTray}`];
            
            trayStates[currentTray] = caps.map(cap => {
                const id = parseInt(cap.dataset.id);
                return trayData.caps.find(c => c.id === id);
