            `;
            
            // Score details per tray
            const scoresGrid = document.getElementById('scoresGrid');
            scoresGrid.innerHTML = '';
            
            for (let t = 1; t <= 4; t++) {
                const trayScores = results.scores.filter(s => s.tray === t);
