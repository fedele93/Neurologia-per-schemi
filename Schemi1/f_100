                            <div class="score-row">
                                <span class="cap-id">Cap ${s.capId}</span>
                                <span class="error ${s.error >= 4 ? 'high' : s.error >= 2 ? 'medium' : 'low'}">${s.error}</span>
                            </div>
                        `).join('')}
                    </div>
                `;
                scoresGrid.innerHTML += trayHtml;
            }
            
            // Print date
            const now = new Date();
            document.getElementById('printDate').textContent = `Report generato il ${now.toLocaleDateString('it-IT')} alle ${now.toLocaleTimeString('it-IT')}`;
        }

        function drawPolarChart(scores) {
            const canvas = document.getElementById('polarChart');
            const ctx = canvas.getContext('2d');
            const centerX = canvas.width / 2;
            const centerY = canvas.height / 2;
            const maxRadius = Math.min(centerX, centerY) - 50;
            
            // Clear canvas
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            
            // Background
            ctx.fillStyle = '#12121a';
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            
            // Draw concentric circles (error scale)
            const maxError = Math.max(...scores.map(s => s.error), 8);
            const errorScale = maxRadius / maxError;
            
            for (let i = 2; i <= maxError; i += 2) {
                ctx.beginPath();
                ctx.arc(centerX, centerY, i * errorScale, 0, Math.PI * 2);
                ctx.strokeStyle = 'rgba(255, 255, 255, 0.1)';
                ctx.lineWidth = 1;
                ctx.stroke();
                
                // Label
                ctx.fillStyle = 'rgba(255, 255, 255, 0.3)';
                ctx.font = '10px DM Sans';
                ctx.fillText(i.toString(), centerX + 5, centerY - i * errorScale + 3);
            }
            
            // Draw axis lines and labels
            const axes = [
                { angle: 0, label: '1' },
                { angle: Math.PI / 4, label: '22' },
                { angle: Math.PI / 2, label: '43' },
                { angle: 3 * Math.PI / 4, label: '64' },
                { angle: Math.PI, label: '85' },
                { angle: 5 * Math.PI / 4, label: '' },
                { angle: 3 * Math.PI / 2, label: '' },
                { angle: 7 * Math.PI / 4, label: '' }
            ];
            
            axes.forEach(axis => {
                ctx.beginPath();
                ctx.moveTo(centerX, centerY);
                ctx.lineTo(
                    centerX + Math.cos(axis.angle - Math.PI / 2) * maxRadius,
                    centerY + Math.sin(axis.angle - Math.PI / 2) * maxRadius
                );
                ctx.strokeStyle = 'rgba(255, 255, 255, 0.1)';
                ctx.stroke();
                
                if (axis.label) {
                    ctx.fillStyle = 'rgba(255, 255, 255, 0.5)';
                    ctx.font = '12px DM Sans';
                    ctx.fillText(
                        axis.label,
                        centerX + Math.cos(axis.angle - Math.PI / 2) * (maxRadius + 20) - 8,
                        centerY + Math.sin(axis.angle - Math.PI / 2) * (maxRadius + 20) + 4
                    );
                }
            });
            
            // Plot error scores
            const numCaps = 84;
            scores.forEach((score, index) => {
                const angle = ((score.capId - 1) / numCaps) * Math.PI * 2 - Math.PI / 2;
                const radius = Math.max(score.error, 0.5) * errorScale;
                
                const x = centerX + Math.cos(angle) * radius;
                const y = centerY + Math.sin(angle) * radius;
                
                // Get color from the cap
                let capColor = '#6366f1';
                for (let t = 1; t <= 4; t++) {
                    const cap = FM100_COLORS[`tray${t}`].caps.find(c => c.id === score.capId);
                    if (cap) {
                        capColor = cap.rgb;
                        break;
                    }
                }
                
                // Draw point
                ctx.beginPath();
                ctx.arc(x, y, 5, 0, Math.PI * 2);
                ctx.fillStyle = capColor;
                ctx.fill();
                ctx.strokeStyle = 'white';
                ctx.lineWidth = 1;
                ctx.stroke();
            });
            
            // Connect points
            ctx.beginPath();
            scores.sort((a, b) => a.capId - b.capId).forEach((score, index) => {
                const angle = ((score.capId - 1) / numCaps) * Math.PI * 2 - Math.PI / 2;
                const radius = Math.max(score.error, 0.5) * errorScale;
                
                const x = centerX + Math.cos(angle) * radius;
                const y = centerY + Math.sin(angle) * radius;
                
                if (index === 0) {
                    ctx.moveTo(x, y);
                } else {
                    ctx.lineTo(x, y);
                }
            });
            ctx.closePath();
            ctx.strokeStyle = 'rgba(99, 102, 241, 0.5)';
            ctx.lineWidth = 1.5;
            ctx.stroke();
            ctx.fillStyle = 'rgba(99, 102, 241, 0.1)';
            ctx.fill();
            
            // Draw confusion axes indicators
            // Protan axis (around 0°)
            drawAxisIndicator(ctx, centerX, centerY, maxRadius, -15, 'Protan', '#ef4444');
            // Deutan axis (around 90°)
            drawAxisIndicator(ctx, centerX, centerY, maxRadius, 75, 'Deutan', '#22c55e');
            // Tritan axis (around 180°)  
            drawAxisIndicator(ctx, centerX, centerY, maxRadius, 150, 'Tritan', '#3b82f6');
        }

        function drawAxisIndicator(ctx, cx, cy, radius, capPosition, label, color) {
            const angle = ((capPosition) / 84) * Math.PI * 2 - Math.PI / 2;
            
            // Draw axis line
            ctx.beginPath();
            ctx.moveTo(cx, cy);
            const x2 = cx + Math.cos(angle) * radius;
            const y2 = cy + Math.sin(angle) * radius;
            ctx.lineTo(x2, y2);
            ctx.strokeStyle = color;
            ctx.lineWidth = 2;
            ctx.setLineDash([5, 5]);
            ctx.stroke();
            ctx.setLineDash([]);
        }

        function printResults() {
            window.print();
        }

        function exportJSON() {
            const data = {
                patient: {
                    name: document.getElementById('patientName').value,
                    dateOfBirth: document.getElementById('patientDob').value,
                    eye: document.getElementById('patientEye').value
                },
                examiner: document.getElementById('examiner').value,
                examDate: document.getElementById('examDate').value,
                illuminant: document.getElementById('illuminant').value,
                duration: elapsedSeconds,
                results: results,
                clinicalNotes: document.getElementById('clinicalNotes').value,
                arrangement: trayStates
            };
            
            const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `FM100_${data.patient.name || 'paziente'}_${data.examDate}.json`;
            a.click();
            URL.revokeObjectURL(url);
        }
    </script>
